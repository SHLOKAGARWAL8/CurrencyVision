<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.MainController"
            prefWidth="1200"
            prefHeight="800">

    <!-- ================= TOP BAR ================= -->

    <top>

        <HBox spacing="15"
              alignment="CENTER_LEFT"
              styleClass="top-bar">

            <padding>
                <Insets top="15" right="20" bottom="15" left="20"/>
            </padding>

            <Label text="🌍 Real-Time Currency Converter"
                   styleClass="title"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button fx:id="refreshButton"
                    text="Refresh"/>

            <Button fx:id="themeButton"
                    text="Dark Mode"/>

        </HBox>

    </top>

    <!-- ================= CENTER ================= -->

    <center>

        <VBox spacing="25">

            <padding>
                <Insets top="25"
                        right="25"
                        bottom="25"
                        left="25"/>
            </padding>

            <!-- Converter Card -->

            <VBox spacing="18"
                  styleClass="card">

                <padding>
                    <Insets top="20"
                            right="20"
                            bottom="20"
                            left="20"/>
                </padding>

                <Label text="Currency Converter"
                       styleClass="section-title"/>

                <Label text="Amount"/>

                <TextField fx:id="amountField"
                           promptText="Enter amount"/>

                <HBox spacing="20"
                      alignment="CENTER_LEFT">

                    <VBox spacing="8">

                        <Label text="From"/>

                        <ComboBox fx:id="fromCurrencyBox"
                                  prefWidth="220"/>

                    </VBox>

                    <Button fx:id="swapButton"
                            text="⇄"
                            prefWidth="70"
                            prefHeight="40"/>

                    <VBox spacing="8">

                        <Label text="To"/>

                        <ComboBox fx:id="toCurrencyBox"
                                  prefWidth="220"/>

                    </VBox>

                </HBox>

                <HBox spacing="15">

                    <Button fx:id="convertButton"
                            text="Convert"
                            prefWidth="180"/>

                    <ProgressIndicator fx:id="loadingIndicator"
                                       visible="false"
                                       prefWidth="35"
                                       prefHeight="35"/>

                </HBox>

            </VBox>
                        <!-- Result Card -->

            <VBox spacing="15"
                  styleClass="card">

                <padding>
                    <Insets top="20"
                            right="20"
                            bottom="20"
                            left="20"/>
                </padding>

                <Label text="Conversion Result"
                       styleClass="section-title"/>

                <Label text="Converted Amount"/>

                <Label fx:id="resultLabel"
                       text="₹ 0.00"
                       styleClass="result"/>

                <Separator/>

                <GridPane hgap="15"
                          vgap="12">

                    <Label text="Exchange Rate"
                           GridPane.rowIndex="0"
                           GridPane.columnIndex="0"/>

                    <Label fx:id="exchangeRateLabel"
                           text="--"
                           GridPane.rowIndex="0"
                           GridPane.columnIndex="1"/>

                    <Label text="Last Updated"
                           GridPane.rowIndex="1"
                           GridPane.columnIndex="0"/>

                    <Label fx:id="lastUpdatedLabel"
                           text="--"
                           GridPane.rowIndex="1"
                           GridPane.columnIndex="1"/>

                    <Label text="API Status"
                           GridPane.rowIndex="2"
                           GridPane.columnIndex="0"/>

                    <Label fx:id="statusLabel"
                           text="🟡 Waiting..."
                           GridPane.rowIndex="2"
                           GridPane.columnIndex="1"/>

                </GridPane>

            </VBox>

            <!-- Trend Graph Card -->

            <VBox spacing="15"
                  styleClass="card">

                <padding>
                    <Insets top="20"
                            right="20"
                            bottom="20"
                            left="20"/>
                </padding>

                <HBox spacing="15"
                      alignment="CENTER_LEFT">

                    <Label text="Exchange Rate Trend"
                           styleClass="section-title"/>

                    <Region HBox.hgrow="ALWAYS"/>

                    <ComboBox fx:id="periodBox"
                              prefWidth="150"/>

                </HBox>
                                <LineChart fx:id="trendChart"
                           animated="true"
                           createSymbols="true"
                           legendVisible="false"
                           prefHeight="350">

                    <xAxis>
                        <CategoryAxis label="Date"/>
                    </xAxis>

                    <yAxis>
                        <NumberAxis label="Exchange Rate"/>
                    </yAxis>

                </LineChart>

            </VBox>

            <!-- History Card -->

            <VBox spacing="15"
                  styleClass="card">

                <padding>
                    <Insets top="20"
                            right="20"
                            bottom="20"
                            left="20"/>
                </padding>

                <HBox alignment="CENTER_LEFT">

                    <Label text="Recent Conversion History"
                           styleClass="section-title"/>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Button fx:id="clearHistoryButton"
                            text="Clear History"/>

                </HBox>

                <TableView fx:id="historyTable"
                           prefHeight="220">

                    <columns>

                        <TableColumn fx:id="timeColumn"
                                     text="Time"
                                     prefWidth="170"/>

                        <TableColumn fx:id="fromColumn"
                                     text="From"
                                     prefWidth="110"/>

                        <TableColumn fx:id="toColumn"
                                     text="To"
                                     prefWidth="110"/>

                        <TableColumn fx:id="amountColumn"
                                     text="Amount"
                                     prefWidth="140"/>

                        <TableColumn fx:id="resultColumn"
                                     text="Converted"
                                     prefWidth="180"/>

                    </columns>

                </TableView>

            </VBox>
             
            <HBox spacing="15"
                  alignment="CENTER_LEFT"
                  styleClass="status-bar">

                <padding>
                    <Insets top="10"
                            right="15"
                            bottom="10"
                            left="15"/>
                </padding>

                <Label text="Status:"/>

                <Label fx:id="connectionStatusLabel"
                       text="🟢 Ready"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Label text="Powered by Frankfurter API"/>

            </HBox>

        </VBox>

    </center>

</BorderPane>